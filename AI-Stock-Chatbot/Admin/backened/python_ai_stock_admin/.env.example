# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_stock_db
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_stock_db

# ── JWT ───────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── App ───────────────────────────────────────────────────────────
APP_NAME=AI Stock Chatbot Admin
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Email (SMTP) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@aistockbot.com

# ── SuperAdmin seed ───────────────────────────────────────────────
SUPERADMIN_EMAIL=superadmin@aistockbot.com
SUPERADMIN_PASSWORD=SuperAdmin@123
SUPERADMIN_USERNAME=superadmin
